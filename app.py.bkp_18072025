@app.route("/upload", methods=["POST"])
def upload():
    bank = request.form['bank']
    period = request.form['period']
    file = request.files['file']
    now = datetime.now()

    if file:
        content = file.read()
        filename = file.filename
        mimetype = file.mimetype

        conn = get_connection()
        cursor = conn.cursor()
        cursor.execute("""
            UPDATE SLA SET 
                SLA_DOC = :blob, 
                SLA_DOC_FILENAME = :filename,
                SLA_DOC_TYPE = :type,
                UPLOAD_DATE = :upload_date,
                MODIFIED_DATE = :modified_date
            WHERE BANK_NAME = :bank AND PERIOD = :period
        """, {
            'blob': content,
            'filename': filename,
            'type': mimetype,
            'upload_date': now,
            'modified_date': now,
            'bank': bank,
            'period': period
        })
        conn.commit()
        cursor.close()
        conn.close()
    return redirect("/")

@app.route("/download")
def download_file():
    bank = request.args.get('bank')
    period = request.args.get('period')

    conn = get_connection()
    cursor = conn.cursor()
    try:
        cursor.execute("""
            SELECT SLA_DOC, SLA_DOC_FILENAME, SLA_DOC_TYPE
            FROM SLA
            WHERE BANK_NAME = :bank AND PERIOD = :period
        """, {'bank': bank, 'period': period})

        row = cursor.fetchone()
        if row and row[0] is not None:
            # ✅ Read LOB data immediately
            blob_data = row[0].read()
            filename = row[1]
            filetype = row[2]
            return send_file(io.BytesIO(blob_data), download_name=filename, mimetype=filetype)

        return "File not found", 404
    except Exception as e:
        return f"Error: {str(e)}", 500
    finally:
        cursor.close()
        conn.close()

@app.route("/delete", methods=["POST"])
def delete_file():
    bank = request.form['bank']
    period = request.form['period']
    now = datetime.now()

    conn = get_connection()
    cursor = conn.cursor()
    cursor.execute("""
        UPDATE SLA SET 
            SLA_DOC = NULL, 
            SLA_DOC_FILENAME = NULL, 
            SLA_DOC_TYPE = NULL,
            MODIFIED_DATE = :modified_date
        WHERE BANK_NAME = :bank AND PERIOD = :period
    """, {'bank': bank, 'period': period, 'modified_date': now})
    conn.commit()
    cursor.close()
    conn.close()
    return redirect("/")
    
@app.route("/update_field", methods=["POST"])
def update_field():
    if session.get("role") != "admin":
        return jsonify({"success": False, "message": "Unauthorized"}), 403

    data = request.get_json()
    bank = data['bank']
    period = data['period']
    field = data['field']
    value = data['value']

    conn = get_connection()
    cursor = conn.cursor()

    try:
        sql = f"UPDATE SLA SET {field} = :value WHERE BANK_NAME = :bank AND PERIOD = :period"
        cursor.execute(sql, {'value': value, 'bank': bank, 'period': period})
        conn.commit()
        return jsonify({"success": True})
    except Exception as e:
        return {"success": False, "message": str(e)}
    finally:
        cursor.close()
        conn.close()

if __name__ == "__main__":
    #app.run(debug=True)
    app.run(host='0.0.0.0', port=5000, debug=True)
