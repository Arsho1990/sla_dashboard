  <!-- Scripts -->
  <script>
    // Theme Toggle
    function toggleTheme() {
      const html = document.documentElement;
      const isDarkMode = html.classList.toggle('dark-mode');
      localStorage.setItem('theme', isDarkMode ? 'dark' : 'light');
      updateThemeIcon();
      
      // Redraw all charts with new colors
      setTimeout(() => {
        reloadChartsWithNewTheme();
      }, 100);
    }

    function updateThemeIcon() {
      const icon = document.querySelector('.theme-toggle');
      const isDarkMode = document.documentElement.classList.contains('dark-mode');
      icon.textContent = isDarkMode ? '☀️' : '🌙';
    }

    function reloadChartsWithNewTheme() {
      const selectedYear = document.getElementById('year') ? document.getElementById('year').value : '';
      const selectedBank = document.getElementById('bank') ? document.getElementById('bank').value : '';
      
      // Reload charts by calling loadCharts
      loadCharts(selectedYear, selectedBank);
    }

    // Bank Name Sorting - Global state
    let bankSortOrder = 'asc'; // 'asc' or 'desc'

    function sortTableByBankName() {
      const tbody = document.getElementById('slaTableBody');
      const icon = document.getElementById('bankSortIcon');
      const rows = Array.from(document.querySelectorAll('#slaTableBody .sla-row'));

      // Sort rows by bank name
      rows.sort((a, b) => {
        const bankA = a.getAttribute('data-bank') || '';
        const bankB = b.getAttribute('data-bank') || '';
        
        if (bankSortOrder === 'asc') {
          return bankA.localeCompare(bankB);
        } else {
          return bankB.localeCompare(bankA);
        }
      });

      // Use fragment for efficient DOM updates
      const fragment = document.createDocumentFragment();
      rows.forEach(row => fragment.appendChild(row));
      tbody.innerHTML = '';
      tbody.appendChild(fragment);

      // Toggle sort order
      bankSortOrder = bankSortOrder === 'asc' ? 'desc' : 'asc';

      // Update icon
      icon.textContent = bankSortOrder === 'asc' ? '↑ A-Z' : '↓ Z-A';

      // Re-apply filter after sort
      const selectedBank = document.getElementById('bank').value || '';
      const filteredRows = document.querySelectorAll('#slaTableBody .sla-row');
      filteredRows.forEach(row => {
        const bankName = row.getAttribute('data-bank');
        if (selectedBank === '' || bankName === selectedBank) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    }

    // Update STATUS or DOC_TYPE field for SLA row
    function updateStatus(bank, period, value, field) {
      var f = field || 'STATUS';
      fetch('/update_field', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bank: bank, period: period, field: f, value: value })
      }).then(r => r.json()).then(res => {
        if (!res.success) alert('Failed to update ' + f + ': ' + (res.message || ''));
      });
    }

    // Apply all filters (table + charts)
    function applyAllFilters() {
      const selectedBank = document.getElementById('bank').value || '';
      const selectedYear = document.getElementById('year').value || '';
      
      console.log('🔄 Applying filters - Bank:', selectedBank || 'All Banks', 'Year:', selectedYear || 'All Years');
      
      // Filter SLA Data Table
      const rows = document.querySelectorAll('#slaTableBody .sla-row');
      rows.forEach(row => {
        const bankName = row.getAttribute('data-bank');
        if (selectedBank === '' || bankName === selectedBank) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });

      // Always reload charts when ANY filter changes
      console.log('📊 Triggering chart reload...');
      reloadChartsWithNewFilters();
    }

    // Reload charts with new filters
    async function reloadChartsWithNewFilters() {
      const selectedYear = document.getElementById('year').value || '';
      const selectedBank = document.getElementById('bank').value || '';
      
      console.log('🔄 reloadChartsWithNewFilters - Bank:', selectedBank || 'All', 'Year:', selectedYear || 'All');
      
      // Build URL with both filters
      const params = new URLSearchParams();
      if (selectedBank) {
        params.append('bank', selectedBank);
        console.log('  ✓ Adding bank param:', selectedBank);
      }
      if (selectedYear) {
        params.append('year', selectedYear);
        console.log('  ✓ Adding year param:', selectedYear);
      }
      
      const newUrl = params.toString() ? '?' + params.toString() : '/dashboard';
      console.log('📍 New URL:', newUrl);
      window.history.replaceState({}, '', newUrl);
      
      // Fetch and render charts
      console.log('⏳ Waiting 150ms before fetching charts...');
      await new Promise(resolve => setTimeout(resolve, 150));
      
      console.log('📊 Now calling loadCharts()...');
      await loadCharts();
    }

    // Get chart colors based on theme
    function getChartColors() {
      const isDarkMode = document.documentElement.classList.contains('dark-mode');
      return {
        isDark: isDarkMode,
        textColor: isDarkMode ? '#ffffff' : '#7B2D7F',
        gridColor: isDarkMode ? '#444444' : '#e0e0e0',
        borderColor: isDarkMode ? '#555555' : '#cccccc',
        accentColor: '#9C27B0',
        accentColor2: '#2196F3',
        accentColor3: '#FF9800',
        accentColor4: '#4CAF50'
      };
    }

    // Load theme on page load
    window.addEventListener('DOMContentLoaded', () => {
      const savedTheme = localStorage.getItem('theme') || 'light';
      if (savedTheme === 'dark') {
        document.documentElement.classList.add('dark-mode');
      }
      updateThemeIcon();
    });

    // Collapsible Section
    function toggleCollapsible(header) {
      header.classList.toggle('active');
      const content = header.nextElementSibling;
      content.classList.toggle('active');
    }

    // Tab Switching
    function switchTab(event, tabName) {
      event.preventDefault();
      
      // Hide all tabs
      document.querySelectorAll('.tab-content').forEach(tab => {
        tab.classList.remove('active');
      });
      
      // Deactivate all buttons
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      
      // Show selected tab
      document.getElementById(tabName).classList.add('active');
      event.target.classList.add('active');
    }

    // Session Timer
    let sessionStart = new Date("{{ session['login_time'] }}");

    function updateSessionTimer() {
      let now = new Date();
      let diff = new Date(now - sessionStart);

      let hours = String(diff.getUTCHours()).padStart(2, '0');
      let minutes = String(diff.getUTCMinutes()).padStart(2, '0');
      let seconds = String(diff.getUTCSeconds()).padStart(2, '0');

      document.getElementById('session-timer').innerText = `${hours}:${minutes}:${seconds}`;
    }

    setInterval(updateSessionTimer, 1000);

    // Update Field
    function updateField(cell, bank, period, field) {
      let newValue = cell.innerText.trim().replace(/,/g, '');

      fetch("/update_field", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ bank, period, field, value: newValue })
      })
      .then(res => res.json())
      .then(data => {
        if (!data.success) {
          alert("Update failed: " + data.message);
        } else {
          // ✅ Auto-reload charts after successful cell update
          console.log('✅ Cell updated successfully, reloading charts...');
          setTimeout(() => {
            loadCharts();
          }, 300);
        }
      })
      .catch(error => {
        console.error('Error updating field:', error);
        alert('خرابی: ' + error);
      });
    }

    // Load Charts
    async function loadCharts() {
      try {
        const urlParams = new URLSearchParams(window.location.search);
        const selectedBank = urlParams.get('bank') || '';
        const selectedYear = urlParams.get('year') || '';
        
        console.log('📊 Loading charts with params - Bank:', selectedBank, 'Year:', selectedYear);
        
        const queryString = new URLSearchParams();
        if (selectedBank) queryString.append('bank', selectedBank);
        if (selectedYear) queryString.append('year', selectedYear);
        const queryParam = queryString.toString() ? '?' + queryString.toString() : '';
        
        console.log('🔗 Fetching from /api/sla-usage-data' + queryParam);
        const slaRes = await fetch('/api/sla-usage-data' + queryParam);
        if (!slaRes.ok) throw new Error(`SLA API error: ${slaRes.status}`);
        const slaData = await slaRes.json();
        
        console.log('✅ SLA Data received:', slaData);
        
        const licRes = await fetch('/api/license-usage-data' + queryParam);
        if (!licRes.ok) throw new Error(`License API error: ${licRes.status}`);
        const licData = await licRes.json();
        
        console.log('✅ License Data received:', licData);
        
        // Render SLA Charts
        if (slaData && slaData.currency_distribution) {
          console.log('📈 Rendering Currency Chart with data:', slaData.currency_distribution);
          renderCurrencyChart(slaData.currency_distribution);
        } else {
          console.warn('⚠️ Currency distribution data missing or empty');
        }
        if (slaData && slaData.bank_distribution) {
          console.log('📈 Rendering Bank Chart with data:', slaData.bank_distribution);
          renderBankChart(slaData.bank_distribution, selectedYear, selectedBank);
        } else {
          console.warn('⚠️ Bank distribution data missing or empty');
        }
        if (slaData && slaData.trend_data) {
          console.log('📈 Rendering Trend Chart');
          renderTrendChart(slaData.trend_data, selectedYear);
        }
        
        // Render License Charts
        if (licData && licData.rdv_status) {
          console.log('📈 Rendering Status Charts');
          renderStatusCharts(licData);
        }
        if (licData && licData.license_type_distribution) {
          console.log('📈 Rendering License Distribution Chart');
          renderLicenseDistributionChart(licData.license_type_distribution);
        }
        if (licData && licData.features_usage) {
          console.log('📈 Rendering Features Chart');
          renderFeaturesChart(licData.features_usage);
        }
        if (licData && licData.recent_changes) {
          console.log('📝 Populating Changes Log');
          populateChangesLog(licData.recent_changes);
        }
        
        console.log('✅ All charts rendered successfully!');
      } catch (error) {
        console.error('❌ Error loading charts:', error);
      }
    }

    // Chart Functions
    function renderCurrencyChart(data) {
      console.log('🎨 renderCurrencyChart called with data:', data);
      
      if (!data || data.length === 0) {
        console.warn('⚠️ Currency chart - No data received, skipping render');
        return;
      }
      
      console.log('✅ Currency chart - Data length:', data.length);
      
      // Make sure canvas exists
      const canvas = document.getElementById('currencyChart');
      if (!canvas) {
        console.error('❌ Currency chart canvas not found!');
        return;
      }
      
      const ctx = canvas.getContext('2d');
      const colors = getChartColors();
      const labels = data.map(d => d.currency);
      const values = data.map(d => d.amount);
      
      console.log('📊 Currency labels:', labels);
      console.log('💰 Currency values:', values);
      
      const chartColors = labels.map(l => l === 'PKR' ? colors.accentColor : colors.accentColor2);
      
      // Destroy old instance if it exists
      if (window.currencyChartInstance) {
        console.log('🗑️ Destroying old currency chart instance');
        window.currencyChartInstance.destroy();
      }
      
