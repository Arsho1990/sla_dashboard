    function populateChangesLog(changes) {
      const tbody = document.getElementById('changesLog');
      if (changes.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--text-secondary);">No recent changes</td></tr>';
      } else {
        tbody.innerHTML = changes.map(change => {
          // Format date to show only date and time
          const dateObj = new Date(change.CHANGE_TIME);
          const formattedDate = dateObj.toLocaleString('en-US', { 
            year: 'numeric', 
            month: '2-digit', 
            day: '2-digit', 
            hour: '2-digit', 
            minute: '2-digit',
            second: '2-digit'
          });
          return `
            <tr>
              <td>${change.TABLE_NAME}</td>
              <td>${change.CLIENT_NAME}</td>
              <td>${change.FIELD_NAME}</td>
              <td>${change.OLD_VALUE || '-'}</td>
              <td>${change.NEW_VALUE || '-'}</td>
              <td>${change.CHANGED_BY}</td>
              <td>${formattedDate}</td>
            </tr>
          `;
        }).join('');
      }
    }

