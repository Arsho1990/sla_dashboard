                  {% if role == 'admin' %}
                  <select onchange="updateStatus('{{ row['BANK_NAME'] }}', '{{ row['PERIOD'] }}', this.value, 'DOC_TYPE')"
                    style="padding:4px 8px;border-radius:4px;border:1px solid #ccc;background:var(--bg-primary);color:var(--text-primary);font-size:12px;cursor:pointer;min-width:110px;">
