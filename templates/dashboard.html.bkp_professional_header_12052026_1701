<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SLA Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    /* CSS Variables for Theming */
    :root {
      --bg-primary: #ffffff;
      --bg-secondary: #f5f5f5;
      --bg-tertiary: #efefef;
      --text-primary: #1a1a1a;
      --text-secondary: #666666;
      --border-color: #e0e0e0;
      --header-bg: #1a1a1a;
      --header-text: #ffffff;
      --accent-color: #4B0082;
      --accent-light: #EDE7F6;
      --shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      --table-header-bg: #4B0082;
      --table-header-text: #ffffff;
      --table-row-alternate: #f9f9f9;
      --success-color: #4CAF50;
      --warning-color: #FF9800;
      --danger-color: #D32F2F;
      --info-color: #2196F3;
    }

    /* Dark Mode */
    html.dark-mode {
      --bg-primary: #1e1e1e;
      --bg-secondary: #2d2d2d;
      --bg-tertiary: #3a3a3a;
      --text-primary: #e0e0e0;
      --text-secondary: #a0a0a0;
      --border-color: #444444;
      --header-bg: #0d0d0d;
      --header-text: #ffffff;
      --accent-light: #3d2d5c;
      --shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      --table-row-alternate: #252525;
    }

    /* Global Styles */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: var(--bg-secondary);
      color: var(--text-primary);
      transition: all 0.3s ease;
      line-height: 1.6;
    }

    /* Header Styles */
    .header {
      background-color: var(--header-bg);
      color: var(--header-text);
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: var(--shadow);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .logo {
      height: 40px;
      max-width: 150px;
    }

    .header-title {
      font-size: 24px;
      font-weight: 600;
      color: #BB86FC;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .user-info {
      display: flex;
      align-items: center;
      gap: 15px;
      font-size: 13px;
      color: #b0b0b0;
    }

    .user-info span {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .nav-links {
      display: flex;
      gap: 15px;
      align-items: center;
    }

    .nav-links a {
      color: #b0b0b0;
      text-decoration: none;
      padding: 8px 12px;
      border-radius: 4px;
      transition: all 0.3s ease;
      font-size: 13px;
    }

    .nav-links a:hover {
      background-color: rgba(187, 134, 252, 0.1);
      color: #BB86FC;
    }

    .theme-toggle {
      background: none;
      border: 1px solid #555;
      color: #B0B0B0;
      cursor: pointer;
      padding: 8px 12px;
      border-radius: 4px;
      font-size: 18px;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
    }

    .theme-toggle:hover {
      background-color: rgba(187, 134, 252, 0.1);
      color: #BB86FC;
      border-color: #BB86FC;
    }

    /* Session Timer */
    .session-timer {
      background-color: var(--accent-light);
      color: var(--accent-color);
      padding: 12px 20px;
      font-weight: 600;
      text-align: center;
      border-bottom: 2px solid var(--accent-color);
    }

    /* Main Container */
    .container {
      max-width: 1600px;
      margin: 0 auto;
      padding: 30px 20px;
    }

    /* Page Title */
    .page-title {
      font-size: 32px;
      font-weight: 700;
      color: var(--accent-color);
      margin-bottom: 30px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* Filter Section */
    .filter-section {
      background-color: var(--bg-primary);
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 30px;
      box-shadow: var(--shadow);
      display: flex;
      gap: 20px;
      align-items: flex-end;
      flex-wrap: wrap;
    }

    .filter-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .filter-group label {
      font-weight: 600;
      color: var(--accent-color);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .filter-group select {
      padding: 10px 12px;
      border-radius: 6px;
      border: 2px solid var(--border-color);
      background-color: var(--bg-primary);
      color: var(--text-primary);
      font-weight: 500;
      cursor: pointer;
      transition: all 0.3s ease;
      min-width: 220px;
    }

    .filter-group select:hover,
    .filter-group select:focus {
      border-color: var(--accent-color);
      outline: none;
      box-shadow: 0 0 0 3px var(--accent-light);
    }

    /* Collapsible Section */
    .collapsible-section {
      background-color: var(--bg-primary);
      border-radius: 8px;
      margin-bottom: 30px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .collapsible-header {
      background-color: var(--bg-tertiary);
      padding: 16px 20px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      user-select: none;
      transition: all 0.3s ease;
      border-left: 4px solid var(--accent-color);
    }

    .collapsible-header:hover {
      background-color: var(--accent-light);
    }

    .collapsible-header h3 {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .toggle-icon {
      font-size: 18px;
      transition: transform 0.3s ease;
    }

    .collapsible-header.active .toggle-icon {
      transform: rotate(180deg);
    }

    .collapsible-content {
      padding: 20px;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    .collapsible-content.active {
      max-height: 2000px;
    }

    /* Table Styles */
    table {
      width: 100%;
      border-collapse: collapse;
      background-color: var(--bg-primary);
      color: var(--text-primary);
    }

    th {
      background-color: var(--table-header-bg);
      color: var(--table-header-text);
      padding: 14px 12px;
      text-align: center;
      font-weight: 600;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    td {
      padding: 12px;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
      font-size: 13px;
    }

    tr:nth-child(even) {
      background-color: var(--table-row-alternate);
    }

    tr:hover {
      background-color: var(--accent-light);
    }

    /* Button Styles */
    button, .btn {
      padding: 8px 14px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-weight: 500;
      font-size: 12px;
      transition: all 0.3s ease;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .btn-upload {
      background-color: var(--accent-color);
      color: white;
    }

    .btn-upload:hover {
      background-color: #6A0C9F;
      transform: translateY(-2px);
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    }

    .btn-download {
      background-color: #FF00FF;
      color: white;
    }

    .btn-download:hover {
      background-color: #E600E6;
      transform: translateY(-2px);
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    }

    .btn-delete {
      background-color: var(--danger-color);
      color: white;
    }

    .btn-delete:hover {
      background-color: #B71C1C;
      transform: translateY(-2px);
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    }

    /* Analytics Section */
    .analytics-section {
      background-color: var(--bg-primary);
      border-radius: 8px;
      padding: 30px;
      box-shadow: var(--shadow);
      margin-bottom: 30px;
    }

    .section-title {
      font-size: 24px;
      font-weight: 700;
      color: var(--accent-color);
      margin-bottom: 25px;
      display: flex;
      align-items: center;
      gap: 10px;
      padding-bottom: 15px;
      border-bottom: 3px solid var(--accent-color);
    }

    /* Tab Styles */
    .tab-navigation {
      display: flex;
      gap: 10px;
      margin-bottom: 30px;
      border-bottom: 2px solid var(--border-color);
      flex-wrap: wrap;
    }

    .tab-btn {
      padding: 12px 24px;
      background-color: transparent;
      border: none;
      border-bottom: 3px solid transparent;
      color: var(--text-secondary);
      cursor: pointer;
      font-weight: 600;
      transition: all 0.3s ease;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .tab-btn:hover {
      color: var(--accent-color);
    }

    .tab-btn.active {
      color: var(--accent-color);
      border-bottom-color: var(--accent-color);
      background-color: var(--accent-light);
      border-radius: 6px 6px 0 0;
    }

    .tab-content {
      display: none;
      animation: fadeIn 0.3s ease-in;
    }

    .tab-content.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    /* Chart Grid */
    .chart-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
      gap: 30px;
      margin-bottom: 30px;
      align-items: start;
    }

    .chart-container {
      background-color: var(--bg-secondary);
      padding: 15px;
      border-radius: 8px;
      border-left: 4px solid var(--accent-color);
      display: flex;
      flex-direction: column;
    }

    .chart-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    canvas {
      background-color: var(--bg-primary);
      padding: 8px;
      border-radius: 8px;
      max-height: 280px !important;
    }

    #bankChart {
      max-height: 320px !important;
    }

    #trendChart {
      max-height: 220px !important;
    }

    /* Dark mode chart visibility fixes */
    html.dark-mode canvas {
      background-color: #252525;
    }

    /* Chart text and label visibility */
    .chart-title {
      color: var(--text-primary);
      font-weight: 600;
      margin-bottom: 15px;
    }

    /* Currency Summary */
    .currency-table {
      width: 100%;
      margin-top: 20px;
    }

    .currency-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 15px;
      padding: 15px;
      background-color: var(--bg-secondary);
      border-radius: 8px;
      margin-bottom: 10px;
      border-left: 4px solid var(--accent-color);
    }

    .currency-item {
      text-align: center;
    }

    .currency-label {
      font-size: 12px;
      color: var(--text-secondary);
      text-transform: uppercase;
      font-weight: 600;
      margin-bottom: 5px;
    }

    .currency-value {
      font-size: 18px;
      font-weight: 700;
      color: var(--accent-color);
    }

    /* COMPREHENSIVE MOBILE RESPONSIVE DESIGN */
    
    /* Tablets: 1024px and below */
    @media (max-width: 1024px) {
      .chart-grid {
        grid-template-columns: 1fr;
      }
      
      .header-right {
        gap: 10px;
      }
      
      .nav-links {
        gap: 8px;
      }
      
      .nav-links a {
        padding: 6px 10px;
        font-size: 12px;
      }
      
      .filter-group select {
        min-width: 120px;
      }
      
      .user-info {
        font-size: 11px;
        gap: 8px;
      }
    }
    
    /* Mobile: 768px and below */
    @media (max-width: 768px) {
      /* HEADER STYLES */
      .header {
        flex-direction: column;
        padding: 12px 15px;
        gap: 12px;
        align-items: flex-start;
      }
      
      .header-left {
        gap: 12px;
        width: 100%;
      }
      
      .logo {
        height: 30px;
        max-width: 100px;
      }
      
      .header-title {
        font-size: 18px;
      }
      
      .header-right {
        flex-direction: column;
        width: 100%;
        gap: 10px;
      }
      
      .user-info {
        flex-direction: column;
        font-size: 11px;
        gap: 5px;
        width: 100%;
        align-items: flex-start;
      }
      
      .user-info span {
        width: 100%;
        font-size: 10px;
      }
      
      .nav-links {
        flex-wrap: wrap;
        gap: 6px;
        width: 100%;
      }
      
      .nav-links a {
        padding: 8px 10px;
        font-size: 11px;
        flex: 1;
        min-width: 70px;
        text-align: center;
      }
      
      .theme-toggle {
        width: 38px;
        height: 38px;
        padding: 6px;
        font-size: 16px;
      }
      
      /* CONTAINER & TIMER */
      .container {
        padding: 12px 10px;
        max-width: 100%;
      }
      
      .session-timer {
        padding: 10px 12px;
        font-size: 12px;
      }
      
      /* PAGE TITLE */
      .page-title {
        font-size: 20px;
        margin-bottom: 15px;
        gap: 5px;
      }
      
      /* FILTERS */
      .filter-section {
        flex-direction: column;
        padding: 12px;
        gap: 10px;
      }
      
      .filter-group {
        width: 100%;
      }
      
      .filter-group label {
        font-size: 11px;
      }
      
      .filter-group select {
        width: 100% !important;
        min-width: unset !important;
        padding: 10px 12px;
        font-size: 13px;
      }
      
      /* STATS CARDS */
      [style*="display:flex"][style*="gap:20px"][style*="flex-wrap:wrap"] {
        gap: 10px !important;
        flex-direction: column !important;
      }
      
      [style*="min-width:180px"] {
        min-width: 100% !important;
      }
      
      /* COLLAPSIBLE SECTIONS */
      .collapsible-header h3 {
        font-size: 14px;
        gap: 5px;
      }
      
      .toggle-icon {
        font-size: 16px;
      }
      
      /* TABLE WRAPPER WITH HORIZONTAL SCROLL */
      div[style*="overflow-x: auto"] {
        overflow-x: auto !important;
        overflow-y: visible !important;
        -webkit-overflow-scrolling: touch;
        margin: 0 -10px;
        padding: 0 10px;
      }
      
      table {
        min-width: 1100px !important;
        font-size: 10px;
      }
      
      th {
        padding: 8px 5px;
        font-size: 9px;
      }
      
      td {
        padding: 6px 4px;
        font-size: 10px;
      }
      
      /* CHARTS */
      .chart-grid {
        grid-template-columns: 1fr !important;
        gap: 12px;
      }
      
      .chart-container {
        padding: 10px;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
      
      .chart-title {
        font-size: 12px;
      }
      
      canvas {
        max-height: 250px !important;
        min-height: 200px !important;
      }
      
      #bankChart {
        max-height: 350px !important;
        min-height: 300px !important;
      }
      
      #trendChart {
        max-height: 220px !important;
        min-height: 180px !important;
      }
      
      /* BUTTONS */
      button, .btn {
        padding: 6px 10px;
        font-size: 10px;
      }
      
      /* TABS */
      .tab-navigation {
        gap: 5px;
        margin-bottom: 15px;
      }
      
      .tab-btn {
        padding: 8px 12px;
        font-size: 11px;
      }
      
      /* SECTION TITLE */
      .section-title {
        font-size: 16px;
      }
    }
    
    /* Small Mobile: 480px and below */
    @media (max-width: 480px) {
      .header {
        padding: 10px 8px;
      }
      
      .logo {
        height: 25px;
        max-width: 90px;
      }
      
      .header-title {
        font-size: 14px;
      }
      
      .header-right {
        gap: 6px;
      }
      
      .user-info span {
        display: block !important;
        width: 100%;
      }
      
      .nav-links a {
        font-size: 10px;
        padding: 6px 8px;
        min-width: 60px;
      }
      
      .container {
        padding: 10px 8px;
      }
      
      .page-title {
        font-size: 16px;
      }
      
      .filter-group select {
        font-size: 12px;
      }
      
      table {
        font-size: 9px;
      }
      
      th {
        padding: 6px 3px;
        font-size: 8px;
      }
      
      td {
        padding: 5px 3px;
        font-size: 9px;
      }
      
      .collapsible-header h3 {
        font-size: 12px;
      }
      
      canvas {
        max-height: 280px !important;
        min-height: 240px !important;
      }
      
      #bankChart {
        max-height: 380px !important;
        min-height: 340px !important;
      }
    }

    /* Loading Animation */
    .loading {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 3px solid var(--border-color);
      border-top-color: var(--accent-color);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <div class="header">
    <div class="header-left">
      <img src="{{ url_for('static', filename='avanza-logo.png') }}" alt="Logo" class="logo">
      <div class="header-title">SLA Dashboard</div>
    </div>
    <div class="header-right">
      <div class="user-info">
        <span>👤 {{ session['username'] }}</span>
        <span>🟢 Login: {{ login_time.strftime('%d-%b-%Y %I:%M:%S %p') if login_time else '-' }}</span>
        <span>🔴 Logout: {{ logout_time.strftime('%d-%b-%Y %I:%M:%S %p') if logout_time else '-' }}</span>
      </div>
      <div class="nav-links">
        <a href="/register">👤 Register</a>
        {% if role == 'admin' %}
        <a href="{{ url_for('licenses') }}">📋 Licenses</a>
        <a href="{{ url_for('change_password') }}">🔐 Password</a>
        {% endif %}
        <a href="{{ url_for('sla_page') }}">📊 SLA</a>
        <button class="theme-toggle" onclick="toggleTheme()" title="Toggle Dark/Light Mode">🌙</button>
        <a href="/logout" style="color: #FF6B6B;">🚪 Logout</a>
      </div>
    </div>
  </div>

  <!-- Session Timer -->
  <div class="session-timer">
    ⏱️ Session Time: <span id="session-timer">00:00:00</span>
  </div>

  <!-- Main Container -->
  <div class="container">
    <div class="page-title">📊 SLA & License Management Portal</div>

    <!-- Global Filters for All Data -->
    <div style="background-color: var(--bg-secondary); padding: 15px; border-radius: 8px; margin-bottom: 20px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
      <div style="display: flex; align-items: center; gap: 10px;">
        <label style="font-weight: 600; color: var(--text-primary);">🏦 Filter by Bank:</label>
        <select id="bank" style="padding: 8px 12px; border-radius: 4px; border: 1px solid var(--border-color); background-color: var(--bg-primary); color: var(--text-primary); cursor: pointer; min-width: 200px;" onchange="applyAllFilters()">
          <option value="">All Banks</option>
          {% for bank in all_banks %}
            <option value="{{ bank }}" {% if bank == selected_bank %}selected{% endif %}>{{ bank }}</option>
          {% endfor %}
        </select>
      </div>
      <div style="display: flex; align-items: center; gap: 10px;">
        <label style="font-weight: 600; color: var(--text-primary);">📅 Filter by Year:</label>
        <select id="year" style="padding: 8px 12px; border-radius: 4px; border: 1px solid var(--border-color); background-color: var(--bg-primary); color: var(--text-primary); cursor: pointer; min-width: 150px;" onchange="applyAllFilters()">
          <option value="">All Years</option>
          <option value="2026">2026</option>
          <option value="2025">2025</option>
          <option value="2024">2024</option>
        </select>
      </div>
      <span style="color: var(--text-secondary); font-size: 12px;">✓ Applies to SLA Table and all charts</span>
    </div>

    <!-- Active / Inactive Status Summary Cards -->
    <div style="display:flex;gap:20px;margin-bottom:20px;flex-wrap:wrap;">
      <div style="flex:1;min-width:180px;background:var(--bg-primary);border-radius:8px;padding:20px;box-shadow:var(--shadow);border-left:5px solid #4CAF50;text-align:center;">
        <div style="font-size:12px;text-transform:uppercase;font-weight:600;color:#4CAF50;margin-bottom:8px;">✅ Active Clients</div>
        <div style="font-size:36px;font-weight:700;color:#4CAF50;">{{ active_count }}</div>
      </div>
      <div style="flex:1;min-width:180px;background:var(--bg-primary);border-radius:8px;padding:20px;box-shadow:var(--shadow);border-left:5px solid #D32F2F;text-align:center;">
        <div style="font-size:12px;text-transform:uppercase;font-weight:600;color:#D32F2F;margin-bottom:8px;">❌ Inactive Clients</div>
        <div style="font-size:36px;font-weight:700;color:#D32F2F;">{{ inactive_count }}</div>
      </div>
      <div style="flex:1;min-width:180px;background:var(--bg-primary);border-radius:8px;padding:20px;box-shadow:var(--shadow);border-left:5px solid var(--accent-color);text-align:center;">
        <div style="font-size:12px;text-transform:uppercase;font-weight:600;color:var(--accent-color);margin-bottom:8px;">🏦 Total Clients</div>
