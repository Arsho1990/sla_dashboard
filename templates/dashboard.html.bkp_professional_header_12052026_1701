    function renderTrendChart(data, selectedYear) {
      if (data.length === 0) return;
      const ctx = document.getElementById('trendChart').getContext('2d');
      const colors = getChartColors();
      const periods = data.map(d => d.period);
      
      // Dynamically detect available years from data properties
      const yearColors = {
        2021: { border: '#FF9800', bg: 'rgba(255, 152, 0, 0.15)' },
        2022: { border: '#00BCD4', bg: 'rgba(0, 188, 212, 0.15)' },
        2023: { border: '#36A2EB', bg: 'rgba(54, 162, 235, 0.15)' },
        2024: { border: '#FFCE56', bg: 'rgba(255, 206, 86, 0.15)' },
        2025: { border: '#4BC0C0', bg: 'rgba(75, 192, 192, 0.15)' },
        2026: { border: '#9C27B0', bg: 'rgba(156, 39, 176, 0.15)' },
        2027: { border: '#FF6B6B', bg: 'rgba(255, 107, 107, 0.15)' },
        2028: { border: '#20C997', bg: 'rgba(32, 201, 151, 0.15)' },
        2029: { border: '#FFA94D', bg: 'rgba(255, 169, 77, 0.15)' },
        2030: { border: '#A8E6CF', bg: 'rgba(168, 230, 207, 0.15)' }
      };
      
      const availableYears = [];
      const datasets = [];
      
      // Detect available years from data properties (yXXXX format)
      // First, get all unique year keys from all data objects
      const yearKeys = new Set();
      data.forEach(d => {
        Object.keys(d).forEach(key => {
          if (key.match(/^y\d{4}$/)) {
            yearKeys.add(key);
          }
        });
      });
      
      // Convert year keys to sorted array of years
      const years = Array.from(yearKeys)
        .map(key => parseInt(key.substring(1)))
        .sort((a, b) => a - b);
      
      // Create datasets for years with data
      years.forEach(year => {
        const yearKey = 'y' + year;
        const yearData = data.map(d => d[yearKey] || 0);
        
        // Check if any data exists for this year
        if (yearData.some(val => val !== null && val !== undefined && val !== 0)) {
          availableYears.push(year);
          datasets.push({
            label: year.toString(),
            data: yearData,
            borderColor: yearColors[year]?.border || '#999999',
            backgroundColor: yearColors[year]?.bg || 'rgba(153, 153, 153, 0.15)',
            tension: 0.4,
            fill: true,
            borderWidth: 3
          });
        }
      });
      
      // Update chart title with available years
      let yearRange = availableYears.length > 0 
        ? `(${availableYears[0]}-${availableYears[availableYears.length - 1]})`
        : '';
      document.getElementById('trendChartTitle').innerText = `📉 SLA Usage Trend ${yearRange}`;
      
      if (window.trendChartInstance) window.trendChartInstance.destroy();
      
      window.trendChartInstance = new Chart(ctx, {
        type: 'line',
        data: {
          labels: periods,
          datasets: datasets
        },
        options: {
          responsive: true,
          plugins: { 
            legend: { 
              position: 'bottom',
              labels: {
                color: colors.textColor,
                font: { size: 12, weight: '600' }
              }
            },
            tooltip: {
              backgroundColor: colors.isDark ? '#333333' : '#ffffff',
              titleColor: colors.textColor,
              bodyColor: colors.textColor,
              borderColor: colors.borderColor,
              borderWidth: 1
            }
          },
          scales: {
            x: {
              ticks: { color: colors.textColor },
              grid: { color: colors.gridColor }
            },
            y: { 
              ticks: { 
                color: colors.textColor,
                callback: v => v.toLocaleString()
              },
              grid: { color: colors.gridColor }
            }
          }
        }
      });
    }

