                  {% set fname = row.get('SLA_DOC_FILENAME') %}
                  {% if fname and fname == fname and fname != 'nan' and fname != '' %}
                    <a class="btn btn-download" style="width:34px;height:34px;display:flex;align-items:center;justify-content:center;font-size:16px;" href="/download?bank={{ row['BANK_NAME'] }}&period={{ row['PERIOD'] }}" target="_blank" rel="noopener noreferrer">⬇️</a>
